.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Node modules (for web app)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Next.js build
.next/
out/

# Turbo cache
.turbo/

# Build outputs
build/
dist/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Git
.git/
.gitignore

# Documentation
docs/
*.md
!README.md

# Test fixtures
tests/

# Scripts
scripts/

# Docker compose override
docker-compose.override.yml

# Local infrastructure configs
infra/postgres/data/
infra/redis/dump.rdb
infra/minio/data/
infra/qdrant/storage/
infra/temporal/data/

